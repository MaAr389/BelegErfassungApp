@implements IDisposable
@inject NavigationManager NavigationManager

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <!-- === FÜR MITGLIEDER === -->
        <AuthorizeView Roles="Mitglied">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/dashboard">
                        <span class="bi bi-house-door-fill nav-menu"></span> Home
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/myreceipts">
                        <span class="bi bi-file-earmark nav-menu"></span> Meine Belege
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/member-applications/new">
                        <span class="bi bi-plus-circle nav-menu"></span> Antrag einreichen
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/member-applications">
                        <span class="bi bi-list-ul nav-menu"></span> Übersicht Anträge
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Manage">
                        <span class="bi bi-person-fill nav-menu"></span> Mein Profil
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link" style="border:none;background:none;cursor:pointer;text-align:left;width:100%;">
                            <span class="bi bi-arrow-bar-left nav-menu"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- === FÜR ADMINS === -->
        <AuthorizeView Roles="Administrator">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/myreceipts">
                        <span class="bi bi-file-earmark nav-menu"></span> Meine Belege
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/allreceipts">
                        <span class="bi bi-collection nav-menu"></span> Alle Belege
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/member-applications/new">
                        <span class="bi bi-plus-circle nav-menu"></span> Antrag einreichen
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/member-applications">
                        <span class="bi bi-list-ul nav-menu"></span> Übersicht Anträge
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/auditlog">
                        <span class="bi bi-journal-text nav-menu"></span> Audit Logs
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/users">
                        <span class="bi bi-people-fill nav-menu"></span> Benutzerverwaltung
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/settings">
                        <span class="bi bi-gear-fill nav-menu"></span> Systemeinstellungen
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/Account/Manage">
                        <span class="bi bi-person-fill nav-menu"></span> Mein Profil
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link" style="border:none;background:none;cursor:pointer;text-align:left;width:100%;">
                            <span class="bi bi-arrow-bar-left nav-menu"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
